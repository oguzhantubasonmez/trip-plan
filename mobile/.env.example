EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_auth_domain
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_storage_bucket
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# Google Maps / Places (Haritadan yer ekle için)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# İsteğe bağlı: functions/scripts/backfill-google-place-id.cjs (Firestore’a yazmak için)
# JSON’u Firebase Console → Servis hesaplarından indirip mobile/secrets/ altına koyun.
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-adminsdk.json

# Hava: Open-Meteo (ücretsiz, anahtar gerekmez; istemciden doğrudan istek)

# Davet linki (WhatsApp’ta tıklanabilir https). GitHub Pages vb. üzerindeki invite-redirect sayfasının tam URL’si
# (sorgu ?invite= otomatik eklenir). mobile/invite-redirect.example.html dosyasını kopyalayıp yayınlayın.
# Boş bırakılırsa app.json → extra.inviteWebBaseUrl kullanılır; ikisi de boşsa paylaşımda routewise:// / intent kullanılır.
# EXPO_PUBLIC_INVITE_WEB_URL=https://KULLANICI.github.io/REPO/invite-redirect.html

# RouteWise Pro — Play / App Store abonelik veya ürün sayfası (Profil’de «Satın al» açar)
# EXPO_PUBLIC_PRO_SUBSCRIPTION_URL=https://play.google.com/store/apps/details?id=com.routewise.tripplan

# Affiliate: Booking vb. partner sorgu eki (?aid=... veya &label=...)
# EXPO_PUBLIC_AFFILIATE_BOOKING_QUERY=aid=YOUR_PARTNER_ID

